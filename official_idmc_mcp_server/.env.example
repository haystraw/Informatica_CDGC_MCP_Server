# -----------------------------------------------------------------------
# official_idmc_mcp_server — environment configuration
#
# URL tokens replaced at runtime each session:
#   {pod}          — from user credentials (e.g. dm-us, dmp-us)
#   {pod_location} — extracted from serverUrl after login (e.g. usw1, use4, usw3)
# -----------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Auth / encryption
# ---------------------------------------------------------------------------
ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=
ENROLL_PASSWORD=Change_this_password

# How long (in minutes) an authenticated session is cached before re-authentication.
SESSION_TIMEOUT_MINUTES=20

# ---------------------------------------------------------------------------
# MCP URL prefix map — add a pod:prefix entry for each non-default pod.
# MCP_URL_PREFIX_DEFAULT is used for any pod not listed in the map.
# ---------------------------------------------------------------------------
MCP_URL_PREFIX_MAP={"dmp-us": "a2e-preview-c360"}
MCP_URL_PREFIX_DEFAULT=a2e-prod

# ---------------------------------------------------------------------------
# MCP Server URLs
# Tokens: {url_prefix} (from map above), {pod_location} (from login), {pod} (from credentials)
# ---------------------------------------------------------------------------
ADDRESS_VERIFICATION_URL=https://{url_prefix}-{pod_location}-mcp.{pod}.informaticacloud.com/mcp-servers/public/dqverifyaddress
CDGC_METADATA_SEARCH_URL=https://{url_prefix}-{pod_location}-mcp.{pod}.informaticacloud.com/mcp-servers/public/cdgcsearchmetadata
CUSTOMER_IDENTIFICATION_URL=https://{url_prefix}-{pod_location}-mcp.{pod}.informaticacloud.com/mcp-servers/public/searchcustomer
DATA_PROVISIONING_URL=https://{url_prefix}-{pod_location}-mcp.{pod}.informaticacloud.com/mcp-servers/public/dataprovisioning
JOB_MANAGEMENT_URL=https://{url_prefix}-{pod_location}-mcp.{pod}.informaticacloud.com/mcp-servers/public/jobmanagement

# ---------------------------------------------------------------------------
# AI Assistant — LLM config
# ---------------------------------------------------------------------------
# MCP server URL (set after deploying o-idmc-mcp-server to Cloud Run)
MCP_SERVER_URL=https://test_url.us-central1.run.app

# Claude via Azure AI Foundry
ANTHROPIC_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_BASE_URL=https://yoururl.services.ai.azure.com/anthropic/v1/messages
CLAUDE_MODEL=claude-opus-4-6

# Gemini fallback
GEMINI_API_KEY=xxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.5-flash
